{
  "name": "furtwin",
  "version": "0.1.0",
  "description": "桌面宠物软件 - FurTwin",
  "author": "LeonEleven",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:win": "chcp 65001 >nul && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "predist": "node scripts/check-ffmpeg-assets.mjs && node scripts/build-extract-script.mjs",
    "dist": "electron-vite build && electron-builder --win --config",
    "dist:win": "electron-vite build && electron-builder --win --config -c.win.target=nsis",
    "dist:win:zip": "electron-vite build && electron-builder --win --config -c.win.target=zip"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pngjs": "^7.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
